# ════════════════════════════════════════════════════
#  ScenarioLab Platform — Environment Configuration
# ════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# Values marked (required) must be set for that feature
# to work. All others have sensible defaults.

# ─── LLM Provider ────────────────────────────────────
# Provider: openai | anthropic | ollama | llamacpp |
#           cli-claude | cli-chatgpt | cli-gemini
LLM_PROVIDER=openai

# API key for cloud providers (OpenAI / Anthropic)
LLM_API_KEY=your-api-key-here

# Base URL — override for Azure OpenAI or local proxies
LLM_BASE_URL=https://api.openai.com/v1

# Model name sent to the provider
LLM_MODEL_NAME=gpt-4

# Concurrent in-flight generate() calls per provider key (default for all providers)
# LLM_CONCURRENCY_DEFAULT=3
# Optional JSON overrides by provider key, e.g. keep CLI subprocess providers low:
# LLM_CONCURRENCY_OVERRIDES={"cli-claude":2,"cli-chatgpt":2,"cli-gemini":2,"cli-codex":2,"openai":8}

# ─── Hybrid inference (optional — local hardware acceleration) ───
# INFERENCE_MODE=cloud
# LOCAL_LLM_PROVIDER=ollama
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL_NAME=qwen3:14b
# HYBRID_CLOUD_ROUNDS=1
# Optional: Gemini CLI subprocess timeouts in seconds (cli-gemini)
# GEMINI_CLI_TIMEOUT=120
# GEMINI_CLI_VERSION_CHECK_TIMEOUT=5
# Optional: Claude CLI subprocess timeouts in seconds (cli-claude)
# CLAUDE_CLI_TIMEOUT=120
# CLAUDE_CLI_VERSION_CHECK_TIMEOUT=10

# ─── Integration API admin (/api/v1/api-keys management) ───
# Set to a long random secret. Required for listing/creating/revoking integration API keys.
# The API Keys page asks for this once per tab (session storage) as Authorization: Bearer.
ADMIN_API_KEY=

# Production: expose /api-keys in the Next.js app and sidebar (dev always exposes it).
# NEXT_PUBLIC_ENABLE_API_KEYS_UI=true

# ─── Neo4j Graph Database ─────────────────────────────
# Runs via Docker Compose (./start.sh) or a remote instance.
# Leave as-is for the default Docker setup.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# Optional: prune idle per-seed extraction locks (graph.router) after TTL (seconds).
# GRAPH_SEED_EXTRACTION_LOCK_TTL_SECONDS=3600
# GRAPH_SEED_EXTRACTION_LOCK_CLEANUP_INTERVAL_SECONDS=300

# ─── Miro Board Integration ───────────────────────────
# (optional) Sync simulation outputs to a Miro board
MIRO_API_TOKEN=
MIRO_BOARD_ID=

# ─── MCP (Model Context Protocol) Server ─────────────
# Enable the built-in MCP tool-use server
MCP_SERVER_ENABLED=false

# ─── Market Intelligence APIs ────────────────────────
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=

# ─── Autoresearch (Tavily + SEC EDGAR) ───────────────
# Tavily key for web search in autoresearch (required for /research)
TAVILY_API_KEY=
# SEC EDGAR user-agent string (required for SEC EDGAR calls)
SEC_USER_AGENT=ScenarioLab/1.0 (research@scenariolab.ai)

# ─── Graphiti (temporal context graph, local Neo4j) ───
# Requires OpenAI-compatible key for Graphiti's default LLM + embedder.
GRAPHITI_ENABLED=false
# Neo4j database name (same server as NEO4J_URI). Use a dedicated DB in prod.
NEO4J_GRAPHITI_DATABASE=neo4j
# Optional; if empty, uses LLM_API_KEY when LLM_PROVIDER=openai, else OPENAI_API_KEY
GRAPHITI_OPENAI_API_KEY=
# Optional cap on concurrent Graphiti operations (library default if unset)
# GRAPHITI_MAX_COROUTINES=4
# Prepend Graphiti search snippets to agent prompts (extra cost per turn)
GRAPHITI_INJECT_AGENT_CONTEXT=false

# ─── Simulation limits ───────────────────────────────
SIMULATION_MAX_AGENTS=48
SIMULATION_LLM_PARALLELISM=4
# 0 = off; cap wall-clock time per round (asyncio.wait_for)
SIMULATION_ROUND_TIMEOUT_SECONDS=0

# ─── Voice / Transcription ───────────────────────────
# Whisper model for audio transcription
WHISPER_MODEL=whisper-1
# OpenAI TTS voice (alloy | echo | fable | onyx | nova | shimmer)
TTS_VOICE=alloy
TTS_MODEL=tts-1

# ─── Fine-Tuning ──────────────────────────────────────
FINE_TUNE_DATA_DIR=./fine_tune_data
FINE_TUNE_OUTPUT_DIR=./fine_tune_output

# ─── E2E (Playwright) ─────────────────────────────────
# Base URL for browser tests (default http://localhost:3000). Override in CI/staging.
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# ─── Frontend (Next.js) — optional client error reporting ───
# Sentry browser DSN; ErrorBoundary reports only when set and NODE_ENV=production
NEXT_PUBLIC_SENTRY_DSN=
# Set to false to disable Sentry even when DSN is set (e.g. staging)
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=
