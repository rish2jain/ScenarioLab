  "scenarios": [
    {
      "id": "drug-patent-cliff",
      "name": "Drug Patent Cliff Response",
      "description": "A blockbuster drug faces imminent patent expiration with generic competitors ready to enter. The pharmaceutical company must decide between defensive strategies, pipeline acceleration, or business model pivot.",
      "category": "Portfolio Strategy",
      "typical_duration_rounds": [7, 10],
      "estimated_time_minutes": 30,
      "environment": "boardroom",
      "agent_roster": [
        {
          "role": "Pharma CEO",
          "archetype_id": "ceo",
          "count": 1,
          "customization": {
            "context": "Leading company facing major patent expiration"
          }
        },
        {
          "role": "Chief Scientific Officer",
          "archetype_id": "strategy_vp",
          "count": 1,
          "customization": {
            "context": "Managing R&D pipeline and lifecycle strategies"
          }
        },
        {
          "role": "Chief Commercial Officer",
          "archetype_id": "operations_head",
          "count": 1,
          "customization": {
            "context": "Overseeing market access and commercial strategy"
          }
        },
        {
          "role": "General Counsel",
          "archetype_id": "general_counsel",
          "count": 1,
          "customization": {
            "context": "Managing patent strategy and legal defenses"
          }
        },
        {
          "role": "CFO",
          "archetype_id": "cfo",
          "count": 1,
          "customization": {
            "context": "Modeling revenue impact and investment requirements"
          }
        },
        {
          "role": "Board Member",
          "archetype_id": "board_member",
          "count": 1,
          "customization": {
            "context": "Overseeing long-term shareholder value protection"
          }
        }
      ],
      "round_structure": [
        "Patent cliff briefing: Revenue at risk analysis",
        "Pipeline review: Next-generation drug candidates",
        "Lifecycle management options: Reformulation, combinations",
        "Legal defense strategies: Patent extension tactics",
        "Biosimilar competitive assessment",
        "M&A opportunities: Pipeline acquisition targets",
        "Geographic strategy: Market prioritization",
        "Portfolio rebalancing: Resource allocation",
        "Board presentation: Strategic recommendation",
        "Implementation vote: Commitment to chosen strategy"
      ],
      "seed_material_template": {
        "required": [
          "Patent expiration timeline and geographic coverage",
          "Current drug revenue forecasts",
          "R&D pipeline status and probabilities",
          "Competitive landscape and biosimilar entrants"
        ],
        "optional": [
          "Historical patent cliff case studies",
          "Regulatory pathway analysis for pipeline drugs",
          "M&A target company profiles",
          "Patient advocacy group positions"
        ]
      },
      "expected_deliverables": [
        "Patent cliff response strategy",
        "Revenue protection plan",
        "Pipeline acceleration roadmap",
        "M&A target prioritization"
      ],
      "environment_config": {
        "decision_mechanism": "Board approval for major strategic investments",
        "escalation_trigger": "Regulatory approval risks trigger review",
        "coalition_dynamics": "R&D vs. Commercial priorities tension"
      }
    },
