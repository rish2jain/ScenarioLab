{
  "vertical": "fintech",
  "scenarios": [
    {
      "id": "fintech-disruption-banking",
      "name": "Fintech Disruption in Banking",
      "description": "A challenger bank with innovative digital services threatens to capture significant market share from established incumbent banks. Incumbents must decide whether to acquire, partner, compete directly, or pivot their strategy.",
      "category": "Competitive Strategy",
      "typical_duration_rounds": [6, 8],
      "estimated_time_minutes": 25,
      "environment": "war_room",
      "agent_roster": [
        {
          "role": "Incumbent Bank CEO",
          "archetype_id": "ceo",
          "count": 1,
          "customization": {
            "context": "Leading a traditional bank facing digital disruption"
          }
        },
        {
          "role": "Incumbent Bank CFO",
          "archetype_id": "cfo",
          "count": 1,
          "customization": {
            "context": "Evaluating acquisition and investment scenarios"
          }
        },
        {
          "role": "Challenger Bank CEO",
          "archetype_id": "ceo",
          "count": 1,
          "customization": {
            "context": "Aggressive fintech disruptor seeking market share"
          }
        },
        {
          "role": "Chief Digital Officer",
          "archetype_id": "strategy_vp",
          "count": 1,
          "customization": {
            "context": "Championing digital transformation initiatives"
          }
        },
        {
          "role": "Regulatory Affairs Head",
          "archetype_id": "general_counsel",
          "count": 1,
          "customization": {
            "context": "Navigating banking regulations and compliance"
          }
        },
        {
          "role": "Private Equity Investor",
          "archetype_id": "activist_investor",
          "count": 1,
          "customization": {
            "context": "Evaluating investment opportunities in the sector"
          }
        }
      ],
      "round_structure": [
        "Market assessment: Current competitive position analysis",
        "Strategic options presentation: M&A, partnership, or organic growth",
        "Financial modeling: Cost-benefit analysis of each approach",
        "Regulatory review: Compliance implications of each strategy",
        "Technology evaluation: Digital capabilities assessment",
        "Investor perspective: shareholder value implications",
        "Strategic decision: Commitment to chosen path",
        "Implementation planning: Resource allocation and timeline"
      ],
      "seed_material_template": {
        "required": [
          "Market share data and customer demographics",
          "Financial projections for each strategic option",
          "Technology capability assessment",
          "Regulatory landscape overview"
        ],
        "optional": [
          "Competitor product feature comparison",
          "Customer satisfaction survey data",
          "Technology stack architecture details",
          "M&A precedents in the sector"
        ]
      },
      "expected_deliverables": [
        "Strategic recommendation with rationale",
        "Financial impact analysis",
        "Implementation roadmap",
        "Risk mitigation plan"
      ],
      "environment_config": {
        "decision_mechanism": "Board approval required for major strategic shifts",
        "escalation_trigger": "Regulatory concerns trigger compliance review",
        "coalition_dynamics": "CEO-CFO alliance vs. Digital transformation advocates"
      }
    },
    {
      "id": "digital-payment-regulation",
