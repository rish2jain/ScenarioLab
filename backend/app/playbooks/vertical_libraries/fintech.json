          "archetype_id": "regulator",
          "count": 1,
          "customization": {
            "context": "Enforcing new payment regulations"
          }
        }
      ],
      "round_structure": [
        "Regulatory briefing: Understanding new requirements",
        "Impact assessment: Business model implications",
        "Technical architecture review: Compliance implementation",
        "Partner negotiation: Data sharing agreements",
        "Competitive analysis: Market positioning post-regulation",
        "Compliance roadmap: Implementation timeline",
        "Strategic adaptation: New revenue model finalization"
      ],
      "seed_material_template": {
        "required": [
          "Full text of new payment regulations",
          "Current business model and revenue streams",
          "Technical architecture documentation",
          "Partner agreement frameworks"
